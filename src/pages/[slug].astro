---
import Base from '../layouts/Base.astro';
import {
  getPostBySlug,
  listPublishedPosts,
  formatPublishedDate,
  buildPostBody,
} from '../lib/posts';

export function getStaticPaths() {
  return listPublishedPosts().map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug!)!;

const { html: bodyHtml, toc } = buildPostBody(post.body_html);

const all = listPublishedPosts();
const idx = all.findIndex((p) => p.slug === post.slug);
const next = idx >= 0 ? all[idx + 1] : undefined;
const prev = idx > 0 ? all[idx - 1] : undefined;

const tags = post.tags ?? [];
---

<Base title={`${post.title} · Duresa Kadi`}>
  <main class="page" data-screen-label={`Post — ${post.slug}`}>
    <article class="shell-narrow post-detail">
      <a class="post-back reveal" href="/">← All posts</a>
      {
        post.kicker && (
          <div class="kicker reveal" style="--reveal-delay: 80ms;">
            {post.kicker}
          </div>
        )
      }
      <h1 class="post-headline reveal" style="--reveal-delay: 140ms;">
        {post.title}
      </h1>
      {
        post.standfirst && (
          <p class="post-stand-large reveal" style="--reveal-delay: 220ms;">
            {post.standfirst}
          </p>
        )
      }
      <div class="post-byline reveal" style="--reveal-delay: 280ms;">
        <span class="post-byline-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <path d="M16 2v4M8 2v4M3 10h18" />
          </svg>
          Posted on {formatPublishedDate(post.published_at)}
        </span>
        {
          post.read_time_min && (
            <span class="post-byline-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 6v6l4 2" />
              </svg>
              {post.read_time_min} Minutes
            </span>
          )
        }
        <span class="post-byline-item">
          <strong>By</strong> Duresa Kadi
        </span>
      </div>

      {
        tags.length > 0 && (
          <div class="post-tags reveal" style="--reveal-delay: 340ms;">
            {tags.map((t) => (
              <span class="post-tag">#{t}</span>
            ))}
          </div>
        )
      }
    </article>

    {
      post.hero_image_url && (
        <img
          class="post-hero-image reveal"
          src={post.hero_image_url}
          alt={post.title}
        />
      )
    }

    <article class="shell-narrow">
      {
        toc.length > 1 && (
          <nav class="post-toc reveal" aria-label="Table of contents">
            <div class="post-toc-title">Table of Contents</div>
            <ul class="post-toc-list">
              {toc.map((entry) => (
                <li class={`post-toc-item post-toc-item-l${entry.level}`}>
                  <a href={`#${entry.id}`}>{entry.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }

      <div
        class="post-body-prose reveal"
        style="--reveal-delay: 340ms;"
        set:html={bodyHtml}
      />

      <div class="post-signoff">
        <span class="post-signoff-name">— Duresa Kadi</span>
      </div>

      <div class="post-reactions">
        <button class="share-btn" type="button" data-share
          ><span data-share-label>Share</span></button
        >
      </div>

      <div class="post-foot">
        {prev ? <a href={`/${prev.slug}`}>← {prev.title}</a> : <span />}
        {next ? <a href={`/${next.slug}`}>{next.title} →</a> : <span />}
      </div>
    </article>
  </main>
  <script>
    const shareBtn = document.querySelector(
      '[data-share]',
    ) as HTMLButtonElement | null;
    const shareLabelEl = document.querySelector(
      '[data-share-label]',
    ) as HTMLSpanElement | null;

    shareBtn?.addEventListener('click', async () => {
      if (!shareLabelEl) return;
      const original = shareLabelEl.textContent;
      try {
        await navigator.clipboard.writeText(window.location.href);
        shareLabelEl.textContent = 'Link copied';
      } catch {
        shareLabelEl.textContent = 'Copy failed';
      }
      setTimeout(() => {
        if (shareLabelEl) shareLabelEl.textContent = original ?? 'Share';
      }, 1800);
    });
  </script>
</Base>
