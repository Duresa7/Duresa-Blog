---
import { SITE } from '../lib/site-data';

interface Props {
  size?: 'sm' | 'md';
  className?: string;
}
const { size = 'md', className = '' } = Astro.props;
---

<div class={`social-icons social-icons-${size} ${className}`}>
  <a
    class="social-icon"
    href={SITE.x}
    target="_blank"
    rel="noopener"
    aria-label="X (Twitter)"
    title="X"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        fill="#ffffff"
        d="M18.244 2H21.5l-7.5 8.57L23 22h-6.8l-5.32-6.96L4.8 22H1.54l8.02-9.17L1 2h6.96l4.82 6.37L18.24 2Zm-2.39 18h1.88L7.27 4H5.27l10.58 16Z"
      ></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={SITE.linkedin}
    target="_blank"
    rel="noopener"
    aria-label="LinkedIn"
    title="LinkedIn"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        fill="#0a66c2"
        d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5z"
      ></path>
      <path
        fill="#ffffff"
        d="M7.119 20.452H3.555V9h3.564v11.452zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm13.115 13.019h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286z"
      ></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={SITE.github}
    target="_blank"
    rel="noopener"
    aria-label="GitHub"
    title="GitHub"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        fill="#ffffff"
        d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
      ></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={`mailto:${SITE.email}`}
    aria-label="Email"
    title="Email"
  >
    <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path fill="#4caf50" d="M45,16.2l-5,2.75l-5,4.75L35,40h7c1.657,0,3-1.343,3-3V16.2z"></path>
      <path fill="#1e88e5" d="M3,16.2l3.614,1.71L13,23.7V40H6c-1.657,0-3-1.343-3-3V16.2z"></path>
      <polygon fill="#e53935" points="35,11.2 24,19.45 13,11.2 12,17 13,23.7 24,31.95 35,23.7 36,17"></polygon>
      <path fill="#c62828" d="M3,12.298V16.2l10,7.5V11.2L9.876,8.859C9.132,8.301,8.228,8,7.298,8h0C4.924,8,3,9.924,3,12.298z"></path>
      <path fill="#fbc02d" d="M45,12.298V16.2l-10,7.5V11.2l3.124-2.341C38.868,8.301,39.772,8,40.702,8h0C43.076,8,45,9.924,45,12.298z"></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={SITE.rss}
    aria-label="RSS feed"
    title="RSS"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        fill="#f26522"
        d="M4 4.44v3.06a12.5 12.5 0 0 1 12.5 12.5h3.06A15.56 15.56 0 0 0 4 4.44Zm0 5.55v3.07a6.94 6.94 0 0 1 6.94 6.94h3.06A10 10 0 0 0 4 9.99Zm2.22 7.78a2.22 2.22 0 1 0 0 4.44 2.22 2.22 0 0 0 0-4.44Z"
      ></path>
    </svg>
  </a>
</div>
