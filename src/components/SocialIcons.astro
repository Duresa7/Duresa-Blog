---
import { SITE } from '../lib/site-data';

interface Props {
  size?: 'sm' | 'md';
  className?: string;
}
const { size = 'md', className = '' } = Astro.props;
---

<div class={`social-icons social-icons-${size} ${className}`}>
  <a
    class="social-icon"
    href={SITE.x}
    target="_blank"
    rel="noopener"
    aria-label="X (Twitter)"
    title="X"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M18.244 2H21.5l-7.5 8.57L23 22h-6.8l-5.32-6.96L4.8 22H1.54l8.02-9.17L1 2h6.96l4.82 6.37L18.24 2Zm-2.39 18h1.88L7.27 4H5.27l10.58 16Z"
      ></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={SITE.linkedin}
    target="_blank"
    rel="noopener"
    aria-label="LinkedIn"
    title="LinkedIn"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.38 4.28 5.47v6.27ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .78 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .78 23.2 0 22.22 0Z"
      ></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={SITE.github}
    target="_blank"
    rel="noopener"
    aria-label="GitHub"
    title="GitHub"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.01-.02-1.99-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.58.23 2.75.12 3.04.74.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.4-5.26 5.68.41.36.78 1.06.78 2.14 0 1.54-.01 2.78-.01 3.16 0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
      ></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={`mailto:${SITE.email}`}
    aria-label="Email"
    title="Email"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <path d="m3 7 9 6 9-6"></path>
    </svg>
  </a>
  <a
    class="social-icon"
    href={SITE.rss}
    aria-label="RSS feed"
    title="RSS"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M4 4.44v3.06a12.5 12.5 0 0 1 12.5 12.5h3.06A15.56 15.56 0 0 0 4 4.44Zm0 5.55v3.07a6.94 6.94 0 0 1 6.94 6.94h3.06A10 10 0 0 0 4 9.99Zm2.22 7.78a2.22 2.22 0 1 0 0 4.44 2.22 2.22 0 0 0 0-4.44Z"
      ></path>
    </svg>
  </a>
</div>
