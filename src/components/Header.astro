---
interface Props {
  current?: 'home' | null;
}
const { current = null } = Astro.props;
---

<nav class="site-nav">
  <div class="site-nav-inner">
    <span
      class="nav-clock"
      data-eastern-clock
      aria-label="Current time in Washington, DC (Eastern)"
    >
      <span class="nav-clock-city">Washington, DC</span>
      <span class="nav-clock-time" data-clock-time>—</span>
    </span>
    <a class="nav-brand" href="/">
      <img
        class="nav-brand-mark"
        src="/images/alphasec-united-logo-only-favicon.png"
        alt=""
        aria-hidden="true"
      />
      <span>Duresa Kadi</span>
    </a>
    <div class="nav-links">
      <a
        class="nav-link"
        href="/"
        aria-current={current === 'home' ? 'page' : undefined}
      >
        Blog
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    var el = document.querySelector('[data-clock-time]');
    if (!el) return;
    var fmt = new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/New_York',
      hour: 'numeric',
      minute: '2-digit',
      second: '2-digit',
      hour12: true,
    });
    function tick() {
      el.textContent = fmt.format(new Date());
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>
